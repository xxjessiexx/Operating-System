<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.SimulationController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <Label text="OS Simulation Dashboard" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Global Time:" styleClass="section-title"/>
            <Label fx:id="globalTimeLabel" text="0" styleClass="global-time"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Next Step"
                    onAction="#handleNextStep"
                    styleClass="button,next-btn"/>

            <Button text="Run Auto"
                    onAction="#handleRunAuto"
                    styleClass="button,auto-btn"/>

            <Button text="Pause"
                    onAction="#handlePause"
                    styleClass="button,pause-btn"/>

            <Button text="Reset"
                    onAction="#handleReset"
                    styleClass="button,reset-btn"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="12" style="-fx-padding: 12;">

            <!-- LEFT COLUMN -->
            <VBox spacing="8" styleClass="card" prefWidth="470" HBox.hgrow="ALWAYS">
                <Label text="Memory Contents" styleClass="section-title"/>
                <TextArea fx:id="memoryArea"
                          wrapText="true"
                          prefHeight="560"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- MIDDLE COLUMN -->
            <VBox spacing="10" prefWidth="420">

                <VBox spacing="6" styleClass="card">
                    <Label text="Disk Contents" styleClass="section-title"/>
                    <TextArea fx:id="diskArea" prefHeight="75" wrapText="true"/>
                </VBox>

                <VBox spacing="6" styleClass="card">
                    <Label text="Ready Queue" styleClass="section-title"/>
                    <TextArea fx:id="readyQueueArea" prefHeight="65" wrapText="true"/>

                    <Label text="Blocked Queue" styleClass="section-title"/>
                    <TextArea fx:id="blockedQueueArea" prefHeight="65" wrapText="true"/>
                </VBox>

                <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="MLFQ Priority Queues" styleClass="section-title"/>

                    <GridPane hgap="8" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <Label text="PQ0" styleClass="small-section-title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="PQ1" styleClass="small-section-title" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <TextArea fx:id="pq0Area" prefHeight="55" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextArea fx:id="pq1Area" prefHeight="55" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="PQ2" styleClass="small-section-title" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label text="PQ3" styleClass="small-section-title" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <TextArea fx:id="pq2Area" prefHeight="55" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextArea fx:id="pq3Area" prefHeight="55" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    </GridPane>
                </VBox>
            </VBox>

            <!-- RIGHT COLUMN -->
            <VBox spacing="10" styleClass="card" prefWidth="320">

                <Label text="Running Process" styleClass="section-title"/>
                <Label fx:id="runningProcessLabel" text="-" styleClass="state-label"/>

                <Separator/>

                <Label text="Current Instruction" styleClass="section-title"/>
                <Label fx:id="currentInstructionLabel"
                       text="-"
                       wrapText="true"
                       styleClass="state-label"/>

                <Separator/>

                <Label text="Scheduler Info" styleClass="section-title"/>
                <Label fx:id="algorithmLabel" text="Algorithm: -" styleClass="state-label"/>
                <Label fx:id="quantumLabel" text="Quantum: -" styleClass="state-label"/>
                <Label fx:id="usedTimeLabel" text="Used Time: -" styleClass="state-label"/>

                <Separator/>

                <Label text="Process States" styleClass="section-title"/>
                <VBox spacing="8">
                    <Label fx:id="p1StateLabel" text="P1: -" styleClass="state-label"/>
                    <Label fx:id="p2StateLabel" text="P2: -" styleClass="state-label"/>
                    <Label fx:id="p3StateLabel" text="P3: -" styleClass="state-label"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>