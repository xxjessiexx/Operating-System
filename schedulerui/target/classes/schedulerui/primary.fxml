<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane prefHeight="768.0" prefWidth="1366.0" styleClass="root-pane"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="schedulerui.PrimaryController">

    <children>
        <Pane prefHeight="768.0" prefWidth="1366.0" styleClass="bg-layer" />
        <Pane prefHeight="78.0" prefWidth="1366.0" styleClass="top-bar" />

        <Button layoutX="18.0" layoutY="12.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="52.0" prefWidth="62.0" styleClass="icon-button">
            <graphic>
                <SVGPath content="M 40 10 L 18 30 L 40 50 M 20 30 H 54 C 64 30 70 24 70 16 C 70 8 64 2 54 2 H 48"
                         styleClass="icon-shape" />
            </graphic>
        </Button>

        <Button layoutX="1282.0" layoutY="12.0" mnemonicParsing="false" onAction="#handleHome" prefHeight="52.0" prefWidth="62.0" styleClass="icon-button">
            <graphic>
                <SVGPath content="M 12 28 L 32 10 L 52 28 L 52 54 H 39 V 38 H 25 V 54 H 12 Z"
                         styleClass="icon-shape" />
            </graphic>
        </Button>

        <SVGPath content="M 35 145 C 15 95, 80 85, 85 150 C 90 215, 25 235, 10 180 C 0 145, 30 130, 52 165 C 85 220, 110 165, 118 72" 
                 fill="TRANSPARENT" layoutX="0.0" layoutY="0.0" stroke="#95A4BE" strokeLineCap="ROUND" strokeWidth="14.0" />

        <SVGPath content="M 1290 700 C 1290 650, 1355 650, 1355 710 C 1355 760, 1295 760, 1295 710 C 1295 670, 1330 665, 1350 700 C 1385 760, 1420 730, 1425 680" 
                 fill="TRANSPARENT" layoutX="0.0" layoutY="0.0" stroke="#95A4BE" strokeLineCap="ROUND" strokeWidth="14.0" />

        <StackPane layoutX="370.0" layoutY="145.0" prefHeight="530.0" prefWidth="660.0" styleClass="glow-card">
            <children>
                <AnchorPane prefHeight="530.0" prefWidth="660.0" styleClass="main-card">
                    <children>
                        <Label layoutX="92.0" layoutY="44.0" styleClass="title-label" text="Choose you scheduler" />

                        <Button layoutX="168.0" layoutY="178.0" mnemonicParsing="false" onAction="#selectRoundRobin" prefHeight="78.0" prefWidth="360.0" styleClass="scheduler-button" text="Round Robin" />
                        <Button layoutX="168.0" layoutY="300.0" mnemonicParsing="false" onAction="#selectHRRN" prefHeight="78.0" prefWidth="360.0" styleClass="scheduler-button" text="HRRN" />
                        <Button layoutX="168.0" layoutY="422.0" mnemonicParsing="false" onAction="#selectMLFQ" prefHeight="78.0" prefWidth="360.0" styleClass="scheduler-button" text="MLFQ" />
                    </children>
                </AnchorPane>
            </children>
        </StackPane>
    </children>
</AnchorPane>